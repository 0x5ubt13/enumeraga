# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
enumeraga

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
# vendor/

# Go workspace file
go.work

# IDE directories to avoid having them rewritten in every commit
.idea/*
.vscode/*
.*
# Keep tracking project config that lives in dot-paths, despite the broad .* rule above
!.github/
!.gitignore
!.golangci.yml
docker_build_test.sh
docker_infra_build_test.sh

# Documentation (except README and VERSIONING)
*.md
!README.md
!VERSIONING.md
!AGENTS.md
!*PROMPTS.md
!SECURITY.md
.DS_Store
internal/cloud/latest
internal/cloud/latestest
enumeraga_output*
